# Elevate U Portal — environment template. Copy to .env and fill in real values.

# MySQL connection. Keep the pool params (shared DB throttles parallel connections).
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/ndhr?connection_limit=5&pool_timeout=30&connect_timeout=30"

# JWT signing secret for session cookies — generate a strong random value in production.
AUTH_SECRET="change_me_to_a_long_random_secret"

# App
APP_NAME="Elevate U"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Donations (Donate Us button → /donate). Optional.
# DONATION_PAYMENT_URL: your payment/checkout link (Razorpay/Stripe/PayU/UPI page).
#   The donate page appends ?amount=<INR>&frequency=<once|monthly>&name=&email=.
# DONATION_UPI_ID: shown as a manual fallback when no payment URL is set.
DONATION_PAYMENT_URL=""
DONATION_UPI_ID=""
